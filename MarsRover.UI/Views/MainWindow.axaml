<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MarsRover.UI.ViewModels"
        xmlns:controls="using:MarsRover.UI.Controls"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="MarsRover.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="MARS ROVER — Q-Learning Pathfinding Agent"
        Width="1400" Height="900"
        MinWidth="920" MinHeight="620"
        Background="#050507"
        Icon="/Assets/logo.ico">
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>
    <Grid ColumnDefinitions="3.4*,1.4*" RowDefinitions="Auto, *" Margin="10">
        <!-- ═══════════════════════════════════════════════
             TOP BAR — Title + Controls
             ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Classes="panel" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*">
                <!-- Title + Team Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="48" Height="48"
                           VerticalAlignment="Center"/>
                    <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="MARS ROVER" FontSize="22" FontWeight="Bold"
                                   Foreground="#EF7E2A" LetterSpacing="4"/>
                        <TextBlock Text="MISSION CONTROL DASHBOARD"
                                   Classes="label" LetterSpacing="3"/>
                    </StackPanel>
                </StackPanel>
                <!-- Training controls -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalAlignment="Stretch"
                              Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="DURATION (h)" Classes="label"/>
                            <NumericUpDown Value="{Binding DurationHours}"
                                       Minimum="24" Maximum="10000"
                                       ClipValueToMinMax="True"
                                       ParsingNumberStyle="Integer"
                                       Width="120" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <TextBlock Text="EPISODES" Classes="label"/>
                            <NumericUpDown Value="{Binding TrainingEpisodes}"
                                       Minimum="100" Maximum="10000"
                                       Width="120" FontSize="13"/>
                        </StackPanel>
                        <Button Content="▶ TRAIN &amp; RUN" Classes="primary"
                            Command="{Binding TrainAndRunCommand}"
                            IsEnabled="{Binding !IsTraining}"
                            VerticalAlignment="Center"/>
                        <Button Content="LOAD MAP" Classes="secondary"
                            Command="{Binding LoadMapCommand}"
                            VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="SPEED" Classes="label" VerticalAlignment="Center"/>
                      <Slider Value="{Binding PlaybackSpeed}"
                                Minimum="1" Maximum="20" Width="120" VerticalAlignment="Center" >   
                             <Slider.Resources>
    <SolidColorBrush x:Key="SliderTrackFill">Gray</SolidColorBrush>
    <SolidColorBrush x:Key="SliderTrackFillPointerOver">Gray</SolidColorBrush>
    <SolidColorBrush x:Key="SliderTrackFillPressed">Gray</SolidColorBrush>

    <SolidColorBrush x:Key="SliderTrackValueFill">#EF7E2A</SolidColorBrush>
    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver">#EF7E2A</SolidColorBrush>
    <SolidColorBrush x:Key="SliderTrackValueFillPressed">#EF7E2A</SolidColorBrush>

    <SolidColorBrush x:Key="SliderThumbBackground">#EF7E2A</SolidColorBrush>
    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver">#EF7E2A</SolidColorBrush>
    <SolidColorBrush x:Key="SliderThumbBackgroundPressed">#EF7E2A</SolidColorBrush> 
  </Slider.Resources>
                      </Slider>
                                
                                
                        </StackPanel>
                        <Button Content="REPLAY" Classes="secondary"
                            Command="{Binding ShowGhostCommand}"
                            VerticalAlignment="Center"/>
                        <Button Content="CHART" Classes="secondary"
                            Command="{Binding ShowChartCommand}"
                            VerticalAlignment="Center"/>
                        <Button Content="MAP" Classes="secondary"
                            Command="{Binding ShowMapCommand}"
                            VerticalAlignment="Center"/>
                        <Button Content="⏮ STEP" Classes="secondary" Command="{Binding ResetCommand}"
                            Classes.grayed="{Binding !HasReplayData}"
                            VerticalAlignment="Center"/>
                        <Button Content="⏵ PLAY" Classes="primary" Command="{Binding PlayCommand}"
                            Classes.grayed="{Binding !HasReplayData}"
                            VerticalAlignment="Center"/>
                        <Button Content="⏸" Classes="secondary" Command="{Binding PauseCommand}"
                            VerticalAlignment="Center"
                            Classes.grayed="{Binding !HasReplayData}"/>
                        <Button Content="⏭ STEP" Classes="secondary" Command="{Binding StepForwardCommand}"
                            Classes.grayed="{Binding !HasReplayData}"
                            VerticalAlignment="Center"/>
                         <Button Content="Back to Main Menu" Classes="secondary" Command="{Binding BackToMenuCommand}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        <!-- ═══════════════════════════════════════════════
             LEFT — Map OR Training Chart + Status bar
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,8,0">
            <!-- MAP VIEW -->
            <Border Classes="panel" Grid.Row="0" Padding="4"
                    IsVisible="{Binding ShowMapView}">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="4,2" CornerRadius="3" Margin="0,0,0,4"
                            Background="#120F12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding DayNightLabel}"
                                       FontWeight="Bold" FontSize="13" Foreground="#F6E8D6"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentTime}"
                                       HorizontalAlignment="Center" Classes="label" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="50×50 MAP"
                                       Classes="label" FontSize="10" LetterSpacing="1"/>
                        </Grid>
                    </Border>
                    <Panel Grid.Row="1">
                        <!-- No-map placeholder -->
                        <Border IsVisible="{Binding !HasMapLoaded}"
                                Background="#050507">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Spacing="12">
                                <TextBlock Text="🗺" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="NO MAP LOADED"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#EF7E2A" LetterSpacing="3"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Click  LOAD MAP  to load a .txt or .csv map file"
                                           FontSize="12" Foreground="#AA7E5D"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Map canvas -->
                        <controls:MapCanvas
                            IsVisible="{Binding HasMapLoaded}"
                            GameMap="{Binding GameMap}"
                            RoverX="{Binding RoverX}"
                            RoverY="{Binding RoverY}"
                            IsNight="{Binding IsNight}"/>
                    </Panel>
                </Grid>
            </Border>
            <!-- GHOST REPLAY VIEW -->
            <Border Classes="panel" Grid.Row="0" Padding="4"
                    IsVisible="{Binding ShowGhostReplay}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="4,2" CornerRadius="3" Margin="0,0,0,4"
                            Background="#120F12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="🧠 TRAINING REPLAY"
                                       FontWeight="Bold" FontSize="13" Foreground="#EF7E2A"/>
                            <TextBlock Grid.Column="1" Text="{Binding GhostStatus}"
                                       HorizontalAlignment="Center" Classes="label" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="GHOST MODE"
                                       Classes="label" FontSize="10" LetterSpacing="1"
                                       Foreground="#EF7E2A"/>
                        </Grid>
                    </Border>
                    <!-- Map -->
                    <controls:MapCanvas Grid.Row="1"
                                        GameMap="{Binding GameMap}"
                                        RoverX="{Binding RoverX}"
                                        RoverY="{Binding RoverY}"
                                        IsNight="False"
                                        GhostTrail="{Binding GhostTrail}"
                                        GhostIndex="{Binding GhostIndex}"
                                        IsGhostMode="True"/>
                    <!-- Live event log with reward/punishment -->
                    <Border Grid.Row="2" Background="#050507" CornerRadius="4"
                            Padding="6,4" Margin="0,4,0,0" Height="105">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,3">
                                <TextBlock Grid.Column="0" Text="EPISODE LOG"
                                           Classes="label" FontSize="10" LetterSpacing="1"
                                           HorizontalAlignment="Left" TextAlignment="Left"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <Border Width="7" Height="7" Background="#3DBA5C"
                                                CornerRadius="3" VerticalAlignment="Center"/>
                                        <TextBlock Text="reward" FontSize="9" Foreground="#3DBA5C"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" TextAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <Border Width="7" Height="7" Background="#EF7E2A"
                                                CornerRadius="3" VerticalAlignment="Center"/>
                                        <TextBlock Text="penalty" FontSize="9" Foreground="#EF7E2A"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" TextAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer Grid.Row="1">
                                <ItemsControl ItemsSource="{Binding GhostEventLog}"
                                              HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10"
                                                       Foreground="#E6B386" Margin="0,1"
                                                       HorizontalAlignment="Left"
                                                       TextAlignment="Left"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <!-- TRAINING CHART VIEW -->
            <Border Classes="panel" Grid.Row="0" Padding="12"
                    IsVisible="{Binding ShowTrainingChart}">
                <Grid RowDefinitions="Auto,*,8,*,8,*">
                    <!-- Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TRAINING CURVE" FontSize="15" FontWeight="Bold"
                                       Foreground="#EF7E2A" LetterSpacing="2"/>
                            <TextBlock Text="Live learning progress - updates on every run"
                                       FontSize="10" Foreground="#D09A70" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="12" Height="3" Background="#3DBA5C"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="Minerals / Episode" FontSize="10"
                                           Foreground="#3DBA5C" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="12" Height="3" Background="#EF7E2A"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="Reward / Episode" FontSize="10"
                                            Foreground="#EF7E2A" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="12" Height="3" Background="#FFD089"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="Battery / Episode" FontSize="10"
                                           Foreground="#FFD089" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <!-- Minerals per episode chart -->
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding TrainingMineralSeries}"
                                        XAxes="{Binding EpisodeAxis}"
                                        YAxes="{Binding MineralYAxis}"
                                        Background="Transparent"
                                        AnimationsSpeed="0:0:0"/>
                    <!-- Reward per episode chart -->
                    <lvc:CartesianChart Grid.Row="3"
                                        Series="{Binding TrainingRewardSeries}"
                                        XAxes="{Binding EpisodeAxis}"
                                        YAxes="{Binding RewardYAxis}"
                                        Background="Transparent"
                                        AnimationsSpeed="0:0:0"/>
                    <!-- Battery over mission ticks chart -->
                    <lvc:CartesianChart Grid.Row="5"
                                        Series="{Binding TrainingBatterySeries}"
                                        XAxes="{Binding EpisodeAxis}"
                                        YAxes="{Binding BatteryYAxis}"
                                        Background="Transparent"
                                        AnimationsSpeed="0:0:0"/>
                </Grid>
            </Border>
            <!-- Progress bar — training progress during training, mission progress otherwise -->
            <Border Grid.Row="1" Classes="panel" Margin="0,8,0,0" Padding="8,6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Mission progress (shown when not training) -->
                    <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center"
                               Text="MISSION PROGRESS" IsVisible="{Binding !IsTraining}"/>
                    <ProgressBar Grid.Column="1" Value="{Binding SimProgress}"
                                 Minimum="0" Maximum="1" Height="6"
                                 Margin="8,0" Foreground="#EF7E2A" Background="#1A1412"
                                 IsVisible="{Binding !IsTraining}"/>
                    <TextBlock Grid.Column="2" Classes="label" VerticalAlignment="Center"
                               Text="{Binding SimProgress, StringFormat={}{0:P0}}"
                               IsVisible="{Binding !IsTraining}"/>
                    <!-- Training progress (shown whenever IsTraining=true, covers ghost+chart modes) -->
                    <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center"
                               Text="TRAINING PROGRESS" IsVisible="{Binding IsTraining}"/>
                    <ProgressBar Grid.Column="1" Value="{Binding TrainingProgress}"
                                 Minimum="0" Maximum="100" Height="6"
                                 Margin="8,0" Foreground="#EF7E2A" Background="#1A1412"
                                 IsVisible="{Binding IsTraining}"/>
                    <TextBlock Grid.Column="2" Classes="label" VerticalAlignment="Center"
                               Text="{Binding TrainingProgress, StringFormat={}{0:F0}%}"
                               IsVisible="{Binding IsTraining}"/>
                </Grid>
            </Border>
        </Grid>
        <!-- ═══════════════════════════════════════════════
             RIGHT — two modes: Training / Mission
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="1" MinWidth="300">
            <Panel>
                <!-- ══ TRAINING MODE PANEL ══════════════════════ -->
                <Grid RowDefinitions="Auto,*"
                      IsVisible="{Binding IsTraining}">
                    <!-- System status + progress -->
                    <Border Grid.Row="0" Classes="panel" Margin="0,0,0,8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="SYSTEM STATUS" Classes="header"/>
                            <TextBlock Text="{Binding TrainingStatus}"
                                       FontSize="11" Foreground="#E6B386"
                                       TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding TrainingProgress}"
                                         Minimum="0" Maximum="100" Height="4"
                                         Foreground="#EF7E2A" Background="#1A1412"/>
                        </StackPanel>
                    </Border>
                    <!-- Training curve charts (fill remaining height) -->
                    <Border Grid.Row="1" Classes="panel">
                        <Grid RowDefinitions="Auto,*,8,*,8,*">
                            <StackPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="TRAINING CURVE" FontSize="15" FontWeight="Bold"
                                           Foreground="#EF7E2A" LetterSpacing="2"/>
                                <TextBlock Text="Updates on every run"
                                           FontSize="10" Foreground="#D09A70" Margin="0,2,0,0"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1"
                                                Series="{Binding TrainingMineralSeries}"
                                                XAxes="{Binding EpisodeAxis}"
                                                YAxes="{Binding MineralYAxis}"
                                                Background="Transparent"
                                                AnimationsSpeed="0:0:0"/>
                            <lvc:CartesianChart Grid.Row="3"
                                                Series="{Binding TrainingRewardSeries}"
                                                XAxes="{Binding EpisodeAxis}"
                                                YAxes="{Binding RewardYAxis}"
                                                Background="Transparent"
                                                AnimationsSpeed="0:0:0"/>
                            <lvc:CartesianChart Grid.Row="5"
                                                Series="{Binding TrainingBatterySeries}"
                                                XAxes="{Binding EpisodeAxis}"
                                                YAxes="{Binding BatteryYAxis}"
                                                Background="Transparent"
                                                AnimationsSpeed="0:0:0"/>
                        </Grid>
                    </Border>
                </Grid>
                <!-- ══ MISSION MODE PANEL ════════════════════════ -->
                <Grid RowDefinitions="Auto,Auto,Auto,*"
                      IsVisible="{Binding !IsTraining}">
                    <!-- System status -->
                    <Border Grid.Row="0" Classes="panel" Margin="0,0,0,8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="SYSTEM STATUS" Classes="header"/>
                            <TextBlock Text="{Binding TrainingStatus}"
                                       FontSize="11" Foreground="#E6B386"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <!-- Rover telemetry -->
                    <Border Grid.Row="1" Classes="panel" Margin="0,0,0,8">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ROVER TELEMETRY" Classes="header"/>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,2">
                                <StackPanel Grid.Column="0" Spacing="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="BATTERY" Classes="label"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Battery, StringFormat={}{0:F1}%}"
                                               Classes="value"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <ProgressBar Value="{Binding Battery}" Minimum="0" Maximum="100"
                                                 Height="4" Margin="0,4,0,0"
                                                 Width="100"
                                                 HorizontalAlignment="Center"
                                                 Foreground="#EF7E2A" Background="#1A1412"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="POSITION" Classes="label" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Classes="value" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center">
                                        <Run Text="{Binding RoverX}"/>
                                        <Run Text=","/>
                                        <Run Text="{Binding RoverY}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,2,0,0">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="DISTANCE" Classes="label" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding DistanceTraveled, StringFormat={}{0:F0} blk}"
                                               Classes="value" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="ACTION" Classes="label" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding LastAction}" Classes="value" FontSize="16"
                                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Spacing="2"
                                            Grid.ColumnSpan="2">
                                <TextBlock Text="MISSION PHASE" Classes="label" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MissionPhase}" FontSize="16"
                                               FontWeight="Bold" Foreground="#D4521A" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Mineral counters -->
                    <Border Grid.Row="2" Classes="panel" Margin="0,0,0,8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="MINERALS COLLECTED" Classes="header"/>
                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="BLUE" FontSize="10" Foreground="#2B7FFF"
                                               HorizontalAlignment="Center" LetterSpacing="1"/>
                                    <TextBlock Text="{Binding MineralsB}" FontSize="26"
                                               FontWeight="Bold" Foreground="#2B7FFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="YELLOW" FontSize="10" Foreground="#FFD700"
                                               HorizontalAlignment="Center" LetterSpacing="1"/>
                                    <TextBlock Text="{Binding MineralsY}" FontSize="26"
                                               FontWeight="Bold" Foreground="#FFD700"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="GREEN" FontSize="10" Foreground="#3DBA5C"
                                               HorizontalAlignment="Center" LetterSpacing="1"/>
                                    <TextBlock Text="{Binding MineralsG}" FontSize="26"
                                               FontWeight="Bold" Foreground="#3DBA5C"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="#F6E8D6">
                                <Run Text="TOTAL: "/>
                                <Run Text="{Binding TotalMinerals}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Event log (expanded to fill freed space) -->
                    <Border Grid.Row="3" Classes="panel">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Text="EVENT LOG" Classes="header"/>
                            <ScrollViewer Grid.Row="1" Margin="0,6,0,0">
                                <ItemsControl ItemsSource="{Binding EventLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="10" Foreground="#AA7E5D"
                                                       Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Panel>
        </Grid>
        <!-- ═══════════════════════════════════════════════
             REPLAY MODE POPUP OVERLAY
             ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#CC000000" IsVisible="{Binding ShowWatchPrompt}"
                ZIndex="100">
            <Border Background="#120F12" CornerRadius="12" Padding="36,28"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="380">
                <StackPanel Spacing="18">
                    <TextBlock Text="REPLAY MODE" FontSize="20" FontWeight="Bold"
                               Foreground="#EF7E2A" HorizontalAlignment="Center"
                               LetterSpacing="3"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#E6B386"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Text="Choose how training replay should run.&#x0a;Fast mode averages chart updates; step-by-step shows every episode."/>
                    <Grid ColumnDefinitions="*,12,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="FAST REPLAY"
                                Classes="primary" HorizontalAlignment="Stretch"
                                Command="{Binding StartFastReplayCommand}"/>
                        <Button Grid.Column="2" Content="STEP-BY-STEP"
                                Classes="secondary" HorizontalAlignment="Stretch"
                                Command="{Binding StartStepByStepReplayCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
