<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════
         MARS ROVER — Dark Space Theme
         Palette: deep space blacks, mars-rust orange,
                  mineral accent blues/yellows/greens
         ═══════════════════════════════════════════════ -->

    <Style Selector="Window">
        <Setter Property="Background" Value="#0D0F14" />
        <Setter Property="Foreground" Value="#E8DCC8" />
        <Setter Property="FontFamily"
                Value="Consolas,Courier New,monospace" />
    </Style>

    <!-- Panel backgrounds -->
    <Style Selector="Border.panel">
        <Setter Property="Background"       Value="#141820" />
        <Setter Property="BorderBrush"      Value="#2A3040" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="6" />
        <Setter Property="Padding"          Value="12" />
    </Style>

    <Style Selector="Border.panel-accent">
        <Setter Property="Background"       Value="#161D28" />
        <Setter Property="BorderBrush"      Value="#D4521A" />
        <Setter Property="BorderThickness"  Value="1,0,0,0" />
        <Setter Property="Padding"          Value="12" />
    </Style>

    <!-- Header labels -->
    <Style Selector="TextBlock.header">
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="FontWeight"   Value="Bold" />
        <Setter Property="Foreground"   Value="#D4521A" />
        <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <Style Selector="TextBlock.value">
        <Setter Property="FontSize"   Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#E8DCC8" />
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="FontSize"   Value="11" />
        <Setter Property="Foreground" Value="#687080" />
    </Style>

    <!-- Buttons -->
    <Style Selector="Button.primary">
        <Setter Property="Background"  Value="#D4521A" />
        <Setter Property="Foreground"  Value="#FFFFFF" />
        <Setter Property="FontWeight"  Value="Bold" />
        <Setter Property="FontSize"    Value="12" />
        <Setter Property="Padding"     Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background"   Value="#1E2530" />
        <Setter Property="Foreground"   Value="#9BA8B8" />
        <Setter Property="BorderBrush"  Value="#2A3040" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize"     Value="12" />
        <Setter Property="Padding"      Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Mineral colour helpers (used in code, referenced here for documentation)
         Blue  mineral: #2B7FFF
         Yellow mineral: #FFD700
         Green  mineral: #3DBA5C
         Obstacle:       #4A4A55
         Surface:        #1E1012   (dark maroon-grey)
         Rover:          #FF6B35  (bright orange)
    -->

</Styles>
