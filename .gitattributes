*.m4a filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.pdb filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.apphost.exe filter=lfs diff=lfs merge=lfs -text

# Training artifacts / model checkpoints (if you decide to commit them)
*.qtable.json filter=lfs diff=lfs merge=lfs -text
*.weights.json filter=lfs diff=lfs merge=lfs -text
*.meta.json filter=lfs diff=lfs merge=lfs -text

# Keep any precomputed resources as LFS (already tracked by directory, but
# this helps if files are added outside `resources/` in the future).
resources/** filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
