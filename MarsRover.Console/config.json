{
  // Path to the 50x50 Mars map CSV file.
  // Can be absolute or relative to the working directory.
  "mapPath": "mars_map_50x50.csv",

  // Mission duration in hours. One Martian sol = 24 hours = 48 ticks.
  "hours": 24,

  // Number of training episodes. More episodes = better policy, slower start.
  // 500 is enough for convergence on this map. 1000+ for tournament runs.
  "episodes": 500,

  // Base name for saved model files.
  // Saves <modelPath>.qtable.json and <modelPath>.meta.json
  "modelPath": "model"
}
